# ============================================
# PorosMadura - Local Development Environment
# ============================================
# Copy this file to `.env` before local development.
# Database, Redis, and Meilisearch internal URLs are provided by docker-compose.yml.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3005
TZ=Asia/Jakarta

# Initial custom CMS admin seed credentials
CMS_ADMIN_EMAIL=admin@porosmadura.local
CMS_ADMIN_PASSWORD=admin12345

# Seed behavior
SEED_DEMO_CONTENT=false
SEED_STATIC_PAGES=true
SEED_OVERWRITE_STATIC_PAGES=false
SEED_AD_SLOTS=true

# Better Auth
BETTER_AUTH_SECRET=local-better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3005

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage
STORAGE_DRIVER=local
NEXT_PUBLIC_MEDIA_URL=/media

# Meilisearch
MEILISEARCH_ENABLED=true

# AI News Generator / 9Router
NINE_ROUTER_BASE_URL=https://9router.tapcode.my.id/v1
NINE_ROUTER_API_KEY=your-9router-api-key
NINE_ROUTER_TEXT_MODEL=my-combo
NINE_ROUTER_FALLBACK_MODEL=my-combo
NINE_ROUTER_IMAGE_MODEL=my-combo

# Optional preview/ngrok origins, comma-separated if more than one
CORS_EXTRA_ORIGINS=

# Optional S3-compatible storage, only used when STORAGE_DRIVER=s3
S3_PUBLIC_URL=
