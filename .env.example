# ============================================
# PorosMadura — Local Development Environment Variables
# ============================================
# Semua URL koneksi internal (Database, Redis, Meilisearch) sudah dikonfigurasi
# secara otomatis di dalam docker-compose.yml. Anda hanya perlu menentukan
# nilai-nilai rahasia (secrets) di bawah ini.
#

# Payload
PAYLOAD_SECRET=your-payload-secret-key-change-in-production

# Better Auth
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3005

# Storage (local)
STORAGE_DRIVER=local
NEXT_PUBLIC_MEDIA_URL=/media

# Meilisearch Configuration
MEILISEARCH_ENABLED=true
MEILISEARCH_API_KEY=master-key

# Site (Port 3005 for local docker-compose app)
NEXT_PUBLIC_SITE_URL=http://localhost:3005
