# ============================================
# Coolify Production — Docker Compose Deployment
# ============================================
# Postgres, Redis, Meilisearch: buat sebagai resource
# terpisah di Coolify (Database / Service).
# Connection string menyesuaikan nama resource di Coolify.
#

# Database (resource name: porosmadura-postgres)
DATABASE_URI=postgres://porosmadura:porosmadura@porosmadura-postgres:5432/porosmadura

# Payload
PAYLOAD_SECRET=change-this-in-production

# Better Auth
BETTER_AUTH_SECRET=change-this-in-production
BETTER_AUTH_URL=${SERVICE_URL_APP}

# Storage (local)
STORAGE_DRIVER=local
NEXT_PUBLIC_MEDIA_URL=/media

# Redis (resource name: porosmadura-redis)
REDIS_URL=redis://porosmadura-redis:6379

# Meilisearch (resource name: porosmadura-meilisearch)
MEILISEARCH_ENABLED=true
MEILISEARCH_HOST=http://porosmadura-meilisearch:7700
MEILISEARCH_API_KEY=master-key

# Site
NEXT_PUBLIC_SITE_URL=${SERVICE_URL_APP}
